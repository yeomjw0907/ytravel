# Amadeus for Developers
# https://developers.amadeus.com/
# 기본 운영 권장:
# - 호텔 자동완성만 사용
# - 가격 비교는 제한 공급처/데모 기준으로 운영

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# 실제 Amadeus Hotel Offers를 검색 결과에 노출할지 여부
# 기본값은 false 권장
AMADEUS_HOTEL_OFFERS_ENABLED=false

# 공개 문의 채널
NEXT_PUBLIC_CONTACT_EMAIL=support@ytravel.kr

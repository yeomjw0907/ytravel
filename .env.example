# Ytravel launch defaults
# Safe default for this week's launch:
# - Use Amadeus for hotel autocomplete only
# - Keep live hotel offers off until API keys are verified

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Set to true only after Amadeus hotel offers are verified end-to-end.
AMADEUS_HOTEL_OFFERS_ENABLED=false

# Public contact channel shown on the site.
NEXT_PUBLIC_CONTACT_EMAIL=support@ytravel.kr
